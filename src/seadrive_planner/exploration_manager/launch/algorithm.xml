<launch>
  <arg name="map_size_x_"/>
  <arg name="map_size_y_"/>
  <arg name="map_size_z_"/>

  <arg name="box_min_x"/>
  <arg name="box_min_y"/>
  <arg name="box_min_z"/>
  <arg name="box_max_x"/>
  <arg name="box_max_y"/>
  <arg name="box_max_z"/>

  <arg name="odometry_topic"/>
  <arg name="sensor_pose_topic"/>
  <arg name="depth_topic"/>
  <arg name="cloud_topic"/>

  <arg name="cx"/>
  <arg name="cy"/>
  <arg name="fx"/>
  <arg name="fy"/>

  <arg name="max_vel"/>
  <arg name="max_acc"/>
  <arg name="usv_fixed_z" default="0.5"/>

  <!-- main node -->
  <node pkg="exploration_manager" name="exploration_node" type="exploration_node" output="screen">
    <remap from ="/odom_world" to="$(arg odometry_topic)"/>
    <remap from ="/map_ros/pose"   to = "$(arg sensor_pose_topic)"/> 
    <remap from ="/map_ros/depth" to = "$(arg depth_topic)"/>
    <remap from ="/map_ros/cloud" to="$(arg cloud_topic)"/>
    <!-- 原来 0.1 分辨率 + 500×500×4 地图，会产生 ~1e9 体素，内存爆掉导致 exploration_node 被 OOM Kill。
         这里改为 0.3m 分辨率，将体素数量降到约 4e7，足够细也更稳定。 -->
    <param name="sdf_map/resolution"      value="0.1" /> 
    <param name="sdf_map/map_size_x"   value="$(arg map_size_x_)" /> 
    <param name="sdf_map/map_size_y"   value="$(arg map_size_y_)" /> 
    <param name="sdf_map/map_size_z"   value="$(arg map_size_z_)" /> 
    <!-- 增大障碍膨胀半径，减少路径贴障 -->
    <param name="sdf_map/obstacles_inflation"     value="0.30" /> 
    <param name="sdf_map/local_bound_inflate"    value="0.5"/>
    <param name="sdf_map/local_map_margin" value="50"/>
    <param name="sdf_map/ground_height"        value="-1.0"/>
    <param name="sdf_map/default_dist"        value="0.0"/>
    
    <param name="sdf_map/p_hit"  value="0.72"/>
    <param name="sdf_map/p_miss" value="0.45"/>
    <param name="sdf_map/p_min"  value="0.12"/>
    <param name="sdf_map/p_max"  value="0.90"/>
    <param name="sdf_map/p_occ"  value="0.70"/>
    <param name="sdf_map/min_ray_length" value="0.5"/>
    <param name="sdf_map/max_ray_length" value="10"/>
    <!-- 传感器模型切换：false=传统逆传感器模型，仅使用点云命中点；true=主动发射射线模型 -->
    <!-- 主动射线建图：在稀疏回波场景下配合保守 no-hit 射线，兼顾前沿与障碍占据显示 -->
    <param name="sdf_map/use_active_sensor_rays" value="true"/>
    <!-- 主动射线模式：32线雷达，垂直FOV固定为 -16deg ~ +15deg，水平360个等角样本 -->
    <param name="sdf_map/active_ray_vertical_lines" value="32"/>
    <param name="sdf_map/active_ray_horizontal_samples" value="360"/>
    <param name="sdf_map/active_ray_vertical_fov_min_deg" value="-16.0"/>
    <param name="sdf_map/active_ray_vertical_fov_max_deg" value="15.0"/>
    <!-- Fix fixed 180deg rotation mismatch by shifting azimuth convention -->
    <param name="sdf_map/active_ray_azimuth_offset_rad" value="3.1415926" type="double"/>
    <param name="sdf_map/virtual_ceil_height"   value="-10"/>
    <!-- 允许略低于水面的回波进入建图，避免前沿在 z 方向被过早截断 -->
    <param name="sdf_map/min_valid_point_z" value="-0.8"/>
    <param name="sdf_map/optimistic" value="false" type="bool"/>
    <param name="sdf_map/signed_dist" value="false" type="bool"/>
    <param name="sdf_map/box_min_x" value="$(arg box_min_x)" type="double"/>
    <param name="sdf_map/box_min_y" value="$(arg box_min_y)" type="double"/>
    <param name="sdf_map/box_min_z" value="$(arg box_min_z)" type="double"/>
    <param name="sdf_map/box_max_x" value="$(arg box_max_x)" type="double"/>
    <param name="sdf_map/box_max_y" value="$(arg box_max_y)" type="double"/>
    <param name="sdf_map/box_max_z" value="$(arg box_max_z)" type="double"/>
    <!-- 地图原点对齐探索框左下角，避免船位姿在地图外导致点云不融合 -->
    <param name="sdf_map/origin_x" value="$(arg box_min_x)" type="double"/>
    <param name="sdf_map/origin_y" value="$(arg box_min_y)" type="double"/>

    <param name="map_ros/cx" value="$(arg cx)"/>
    <param name="map_ros/cy" value="$(arg cy)"/>
    <param name="map_ros/fx" value="$(arg fx)"/>
    <param name="map_ros/fy" value="$(arg fy)"/>
    <param name="map_ros/depth_filter_maxdist"   value="5.0"/>
    <param name="map_ros/depth_filter_mindist"   value="0.2"/>
    <param name="map_ros/depth_filter_margin"    value="2"/>
    <param name="map_ros/k_depth_scaling_factor" value="1000.0"/>
    <param name="map_ros/skip_pixel" value="2"/>
    <param name="map_ros/esdf_slice_height" value="-0.6"/>
    <param name="map_ros/visualization_truncate_height"   value="1.0"/>
    <param name="map_ros/visualization_truncate_low"   value="-1.5"/>
    <!-- 低于 -0.65（大致为水面噪声） 的占据体素不显示在 occupancy_local 中 -->
    <param name="map_ros/occ_z_min" value="-1.20"/>
    <!-- Hard filter water-surface noise before fusing into SDF map -->
    <param name="map_ros/water_filter_enable" value="true" type="bool"/>
    <param name="map_ros/water_filter_z_min" value="-0.2" type="double"/>
    <param name="map_ros/water_filter_z_max" value="0.2" type="double"/>
    <!-- Fix constant 180deg yaw offset between lidar azimuth convention and SDFMap active-ray model -->
    <param name="map_ros/camera_yaw_offset" value="0.0" type="double"/>
    <param name="map_ros/camera_q_conjugate" value="false" type="bool"/>
    <param name="map_ros/show_occ_time"  value="false"/>
    <param name="map_ros/show_esdf_time" value="false"/>
    <!-- 仅发布局部地图，避免 publishMapAll 在大范围地图上产生内存问题 -->
    <param name="map_ros/show_all_map" value="true"/>
    <param name="map_ros/frame_id"      value="world"/>

    <!-- 2D global explored map (OccupancyGrid) -->
    <param name="map_ros/explored_grid_z" value="$(arg usv_fixed_z)" type="double"/>
    <param name="map_ros/explored_grid_z_half_thickness" value="0.25" type="double"/>
    <param name="map_ros/explored_grid_obs_z_min" value="0.1" type="double"/>
    <param name="map_ros/explored_grid_obs_z_max" value="1.2" type="double"/>
    <param name="map_ros/explored_grid_obs_occ_log_soft_thresh" value="0.3" type="double"/>
    <param name="map_ros/explored_grid_pub_dt" value="0.5" type="double"/>
    <param name="map_ros/explored_grid_debug" value="false" type="bool"/>
    <param name="map_ros/explored_grid_debug_throttle" value="2.0" type="double"/>
    <param name="map_ros/cloud_debug" value="false" type="bool"/>
    <param name="map_ros/cloud_debug_throttle" value="2.0" type="double"/>

    <!-- Fsm：船体用较长航段，减少重规划频率（原无人机为 0.5/0.5/1.5） -->
    <param name="fsm/thresh_replan1" value="2.5" type="double"/>
    <param name="fsm/thresh_replan2" value="1.0" type="double"/>
    <param name="fsm/thresh_replan3" value="6.0" type="double"/>
    <param name="fsm/auto_trigger_enable" value="false" type="bool"/>
    <param name="fsm/auto_trigger_delay" value="1.0" type="double"/>

    <!-- USV抗抖保守阈值：进一步减小会频繁重规划 -->
    <param name="fsm/replan_time" value="0.200" type="double"/>

    <!-- Exploration manager -->

    <param name="exploration/refine_local" value="true" type="bool"/>
    <param name="exploration/refined_num" value="7" type="int"/>
    <param name="exploration/refined_radius" value="5.0" type="double"/>
    <param name="exploration/max_decay" value="0.8" type="double"/>
    <param name="exploration/top_view_num" value="15" type="int"/>
    <param name="exploration/vm" value="$(eval 1.0 * arg('max_vel'))" type="double"/>
    <param name="exploration/am" value="$(eval 1.0 * arg('max_acc'))" type="double"/>
    <!-- 限制相邻前沿视角之间的偏航差，避免轨迹出现过大转弯 -->
    <param name="exploration/yd" value="$(eval 30 * 3.1415926 / 180.0)" type="double"/>
    <param name="exploration/ydd" value="$(eval 45 * 3.1415926 / 180.0)" type="double"/>
    <param name="exploration/w_dir" value="1.5" type="double"/>
    <param name="exploration/tsp_dir" value="$(find lkh_tsp_solver)/resource" type="string"/>
    <param name="exploration/relax_time" value="1.0" type="double"/>
    <!-- Global memory from VLM value_map: prefer high-value frontiers and shorter transfer -->
    <param name="exploration/use_value_map_memory" value="true" type="bool"/>
    <param name="exploration/value_map_topic" value="/sdf_map/value_map" type="string"/>
    <param name="exploration/global_reorder_k" value="6" type="int"/>
    <param name="exploration/value_reward_weight" value="3.0" type="double"/>
    <param name="exploration/low_value_penalty_weight" value="1.5" type="double"/>
    <param name="exploration/value_map_sample_radius" value="0.8" type="double"/>
    <param name="exploration/planar_motion" value="true" type="bool"/>
    <param name="exploration/fixed_height" value="$(arg usv_fixed_z)" type="double"/>

    <!-- 为水面+稀疏障碍场景放宽前沿检测阈值 -->
    <!-- <param name="frontier/cluster_min" value="10" type="int"/>
    <param name="frontier/cluster_size_xy" value="9.0" type="double"/>
    <param name="frontier/cluster_size_z" value="2.0" type="double"/>
    <param name="frontier/min_candidate_dist" value="10" type="double"/>
    <param name="frontier/min_candidate_clearance" value="0.42" type="double"/>
    <param name="frontier/candidate_dphi" value="$(eval 15 * 3.1415926 / 180.0)" type="double"/>
    <param name="frontier/candidate_rnum" value="3" type="int"/>
    <param name="frontier/candidate_rmin" value="1.5" type="double"/>
    <param name="frontier/candidate_rmax" value="2.5" type="double"/>
    <param name="frontier/down_sample" value="3" type="int"/>;
    <param name="frontier/min_visib_num" value="15" type="int"/>;
    <param name="frontier/min_view_finish_fraction" value="0.2" type="double"/>; -->

    <param name="frontier/cluster_min" value="6" type="int"/>
    <param name="frontier/frontier_range" value="0.0" type="double"/>
    <!-- 放宽前沿最低高度约束，避免仅保留单层前沿 -->
    <param name="frontier/min_frontier_z" value="-0.8" type="double"/>
    <param name="frontier/enforce_fixed_view_z" value="true" type="bool"/>
    <param name="frontier/fixed_view_z" value="$(arg usv_fixed_z)" type="double"/>
    <param name="frontier/cluster_size_xy" value="2.0" type="double"/>
    <param name="frontier/cluster_size_z" value="5.0" type="double"/>
    <!-- 放宽前沿视点约束，适应小障碍 + 稀疏点云场景 -->
    <param name="frontier/min_candidate_dist" value="0.75" type="double"/>
    <!-- 允许视点更靠近障碍，避免小障碍被全部过滤掉 -->
    <param name="frontier/min_candidate_clearance" value="0.11" type="double"/>
    <param name="frontier/candidate_dphi" value="$(eval 15 * 3.1415926 / 180.0)" type="double"/>
    <param name="frontier/candidate_rnum" value="3" type="int"/>
    <param name="frontier/candidate_rmin" value="1.5" type="double"/>
    <param name="frontier/candidate_rmax" value="2.5" type="double"/>
    <!-- 不再下采样前沿体素，保留更多细小前沿 -->
    <param name="frontier/down_sample" value="1" type="int"/>;
    <!-- 1 个可见体素即可接受视点 -->
    <param name="frontier/min_visib_num" value="3" type="int"/>;
    <param name="frontier/min_view_finish_fraction" value="0.2" type="double"/>;

    <!-- <param name="frontier/cluster_min" value="100" type="int"/>
    <param name="frontier/cluster_size_xy" value="2.0" type="double"/>
    <param name="frontier/cluster_size_z" value="10.0" type="double"/>
    <param name="frontier/min_candidate_dist" value="0.75" type="double"/>
    <param name="frontier/min_candidate_clearance" value="0.21" type="double"/>
    <param name="frontier/candidate_dphi" value="$(eval 15 * 3.1415926 / 180.0)" type="double"/>
    <param name="frontier/candidate_rnum" value="3" type="int"/>
    <param name="frontier/candidate_rmin" value="1.5" type="double"/>
    <param name="frontier/candidate_rmax" value="2.5" type="double"/>
    <param name="frontier/down_sample" value="3" type="int"/>;
    <param name="frontier/min_visib_num" value="15" type="int"/>;
    <param name="frontier/min_view_finish_fraction" value="0.2" type="double"/>; -->

    <!-- Perception utils -->
    <param name="perception_utils/top_angle" value="0.56125" type="double"/>;
    <param name="perception_utils/left_angle" value="1.5" type="double"/>;
    <param name="perception_utils/right_angle" value="1.5" type="double"/>;
    <param name="perception_utils/max_dist" value="5" type="double"/>;
    <param name="perception_utils/vis_dist" value="1.0" type="double"/>;


    <!-- 进一步限制单次规划中允许的偏航变化，生成更平滑的转弯 -->
    <param name="heading_planner/yaw_diff" value="$(eval 15 * 3.1415926 / 180.0)" type="double"/>
    <param name="heading_planner/half_vert_num" value="5" type="int"/>
    <param name="heading_planner/lambda1" value="2.0" type="double"/>
    <param name="heading_planner/lambda2" value="1.0" type="double"/>
    <param name="heading_planner/max_yaw_rate" value="$(eval 10 * 3.1415926 / 180.0)" type="double"/>
    <param name="heading_planner/w" value="20000.0" type="double"/>
    <param name="heading_planner/weight_type" value="1" type="double"/>

  <!-- planner manager：船体用较长单段、较大控制点间距，减少“小步快跑” -->
    <param name="manager/max_vel" value="$(arg max_vel)" type="double"/>
    <param name="manager/max_acc" value="$(arg max_acc)" type="double"/>
    <param name="manager/max_jerk" value="4" type="double"/>
    <param name="manager/dynamic_environment" value="0" type="int"/>
    <param name="manager/local_segment_length" value="12.0" type="double"/>
    <param name="manager/clearance_threshold" value="0.2" type="double"/>
    <param name="manager/control_points_distance" value="3.3" type="double"/>
    <param name="manager/use_geometric_path" value="true" type="bool"/>
    <param name="manager/use_kinodynamic_path" value="true" type="bool"/>
    <param name="manager/use_topo_path" value="true" type="bool"/>
    <param name="manager/use_optimization" value="true" type="bool"/>
    <param name="manager/use_active_perception" value="true" type="bool"/>
    <param name="manager/min_time" value="true" type="bool"/>
    <param name="manager/planar_motion" value="true" type="bool"/>
    <param name="manager/fixed_height" value="$(arg usv_fixed_z)" type="double"/>

  <!-- kinodynamic path searching：船体适当加大前瞻，单段规划更远 -->
    <param name="search/max_tau" value="0.8" type="double"/>
    <param name="search/init_max_tau" value="1.0" type="double"/>
    <param name="search/max_vel" value="$(arg max_vel)" type="double"/>
    <param name="search/vel_margin" value="0.25" type="double"/>
    <param name="search/max_acc" value="$(arg max_acc)" type="double"/>
    <param name="search/w_time" value="10.0" type="double"/>
    <param name="search/horizon" value="10.0" type="double"/>
    <param name="search/lambda_heu" value="10.0" type="double"/>
    <param name="search/resolution_astar" value="0.025" type="double"/>
    <param name="search/time_resolution" value="0.8" type="double"/>
    <param name="search/margin" value="0.2" type="double"/>
    <param name="search/allocate_num" value="100000" type="int"/>
    <param name="search/check_num" value="10" type="int"/>
    <!-- 对未知区域采用乐观策略，避免起始阶段“无路可走” -->
    <param name="search/optimistic" value="true" type="bool"/>
    <param name="search/planar_motion" value="true" type="bool"/>
    <param name="search/fixed_height" value="$(arg usv_fixed_z)" type="double"/>

    <param name="astar/lambda_heu" value="10000.0" type="double"/>
    <param name="astar/resolution_astar" value="0.2" type="double"/>
    <param name="astar/allocate_num" value="1000000" type="int"/>
    <param name="astar/max_search_time" value="0.001" type="double"/>

  <!-- trajectory optimization -->
    <param name="optimization/ld_smooth" value="20.0" type="double"/>
    <param name="optimization/ld_dist" value="10.0" type="double"/>
    <param name="optimization/ld_feasi" value="2.0" type="double"/>
    <param name="optimization/ld_start" value="100.0" type="double"/>
    <param name="optimization/ld_end" value="0.5" type="double"/>
    <param name="optimization/ld_guide" value="1.5" type="double"/>
    <param name="optimization/ld_waypt" value="0.3" type="double"/>
    <param name="optimization/ld_view" value="0.0" type="double"/>
    <param name="optimization/ld_time" value="1.0" type="double"/>
    <param name="optimization/dist0" value="0.7" type="double"/>
    <param name="optimization/max_vel" value="$(arg max_vel)" type="double"/>
    <param name="optimization/max_acc" value="$(arg max_acc)" type="double"/>
    <param name="optimization/algorithm1" value="15" type="int"/>
    <param name="optimization/algorithm2" value="11" type="int"/>
    <param name="optimization/max_iteration_num1" value="2" type="int"/>
    <param name="optimization/max_iteration_num2" value="2000" type="int"/>
    <param name="optimization/max_iteration_num3" value="200" type="int"/>
    <param name="optimization/max_iteration_num4" value="200" type="int"/>

    <param name="optimization/max_iteration_time1" value="0.0001" type="double"/>
    <param name="optimization/max_iteration_time2" value="0.005" type="double"/>
    <param name="optimization/max_iteration_time3" value="0.003" type="double"/>
    <param name="optimization/max_iteration_time4" value="0.003" type="double"/>
    <param name="optimization/planar_motion" value="true" type="bool"/>
    <param name="optimization/fixed_height" value="$(arg usv_fixed_z)" type="double"/>
    <param name="bspline/limit_vel" value="$(arg max_vel)" type="double"/>
    <param name="bspline/limit_acc" value="$(arg max_acc)" type="double"/>
    <param name="bspline/limit_ratio" value="1.1" type="double"/>
    <param name="bspline/limit_vel" value="$(arg max_vel)" type="double"/>
    <param name="bspline/limit_acc" value="$(arg max_acc)" type="double"/>
    <param name="bspline/limit_ratio" value="1.1" type="double"/>

  </node>

</launch>